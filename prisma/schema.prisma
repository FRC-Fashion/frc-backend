
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Identity ──
  name      String
  email     String  @unique
  password  String

  // ── Role & Status ──
  role          Role    @default(USER)
  isActive      Boolean @default(false)
  isEmailVerified Boolean @default(false)

  // ── Email Activation ──
  activationCode        String?
  activationCodeExpires DateTime?

  // ── Forgot Password ──
  forgetCode        String?
  forgetCodeExpires DateTime?
  passwordChangedAt DateTime?

  // ── Profile (to be extended) ──
  // TODO: add more profile fields here (avatar, bio, phone, address, etc.)

  @@map("users")
}